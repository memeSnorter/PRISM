# GitHub Personal Access Token (fallback if OAuth not used)
# Create one at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public only)
GITHUB_TOKEN=your_github_personal_access_token

# GitHub OAuth Configuration
# Create an OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:8000/api/auth/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:3000

# LM Studio Configuration
# Use localhost if running LM Studio on the same machine:
# LM_STUDIO_URL=http://localhost:1234/v1
# Or use a remote LM Studio server IP:
LM_STUDIO_URL=http://100.83.166.216:1234/v1
LM_STUDIO_MODEL=gemma-4-e2b
